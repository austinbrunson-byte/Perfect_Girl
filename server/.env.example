# Copy to .env and fill in. Never commit .env.
PORT=3000

# Secret used to sign JWTs. Generate a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# REQUIRED in production — the server refuses to start without it when NODE_ENV=production.
JWT_SECRET=

# How long a login token stays valid.
JWT_EXPIRES=30d

# Where the SQLite file lives.
DB_PATH=./data/app.db

# Comma-separated list of allowed browser origins for CORS, or * for any (dev only).
# e.g. https://austinbrunson-byte.github.io
CORS_ORIGIN=*
